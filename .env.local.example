# ── DATABASE ─────────────────────────────────────────────────────────────────
# Pooled connection for the app (serverless — connection_limit=1)
DATABASE_URL="postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME?connection_limit=1"

# Direct connection for Prisma CLI migrations (no connection_limit)
DIRECT_URL="postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME"

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID="your-iam-access-key-id"
AWS_SECRET_ACCESS_KEY="your-iam-secret-access-key"
AWS_SES_FROM_ADDRESS="noreply@yourdomain.org"
AWS_SES_FROM_NAME="Satsang Europe"
AWS_S3_BUCKET_NAME="your-s3-bucket-name"

# ── STRIPE ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET=""

# ── AUTH (NextAuth v5) ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-generated-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
